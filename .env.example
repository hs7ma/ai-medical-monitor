# PostgreSQL
POSTGRES_USER=medapp
POSTGRES_PASSWORD=medpassword
POSTGRES_DB=medical_monitor

# InfluxDB
INFLUXDB_USER=medadmin
INFLUXDB_PASSWORD=medpassword
INFLDB_ORG=hospital
INFLUXDB_ORG=hospital
INFLUXDB_BUCKET=vitals
INFLUXDB_TOKEN=medtoken
INFLUXDB_URL=http://influxdb:8086

# MQTT
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=hospital/bed/+/vitals

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=medadmin
MINIO_SECRET_KEY=medsecret123
MINIO_BUCKET=medical-files
MINIO_SECURE=false

# OpenAI (used in Phase 5)
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o

# Security
JWT_SECRET=change-this-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# App
APP_ENV=development
UPLOAD_DIR=/tmp/uploads
MAX_UPLOAD_SIZE_MB=20
